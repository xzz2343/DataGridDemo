# Supabase — copy these from your project at: supabase.com → Settings → API
# Both are safe to expose in the browser; the anon key is restricted by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — used ONLY by scripts/seed.ts (one-time DB seed).
# Never commit this value. Never prefix it with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
